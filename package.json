{
  "name": "@memblin/nats-chat",
  "version": "0.1.0",
  "description": "MCP server for Claude Code inter-session communication via NATS JetStream",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Chris Row <chris.row@discursive.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memblin/nats-chat-mcp.git"
  },
  "homepage": "https://github.com/memblin/nats-chat-mcp#readme",
  "bugs": {
    "url": "https://github.com/memblin/nats-chat-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nats",
    "jetstream",
    "claude",
    "claude-code"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "nats-chat": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "nats": "^2.28.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "testcontainers": "^12.0.2",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
